{
  "permissions": {
    "allow": [
      "Read",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(stat *)",
      "Bash(file *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Bash(*env*)"
    ]
  }
}
