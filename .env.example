# ---------------------------------------------------------
# Branding - set these to customise the site for your org
# ---------------------------------------------------------
BRAND_ORG_NAME="Your Organisation"           # Organisation name shown in headings and footer
BRAND_HOME_URL=https://yourorg.org           # Link for the "Home" button and footer copyright
BRAND_LINKEDIN_URL=                          # LinkedIn URL (leave blank to hide icon)
BRAND_YOUTUBE_URL=                           # YouTube URL (leave blank to hide icon)
# See config/branding.php for colours and logo guidance

APP_NAME="Resources Site Template"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://resources-site-template.test

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=resources_site_template
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail must be configured for user invitations and self-service password resets to work.
MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
VITE_SENTRY_DSN_PUBLIC="${SENTRY_LARAVEL_DSN}"

FILESYSTEM_DISK=s3
MEDIA_DISK=s3

# AWS S3 Storage for trove documents
AWS_ACCESS_KEY_ID=<your-key-id>
AWS_SECRET_ACCESS_KEY=<your-secret-access-key>
AWS_DEFAULT_REGION=eu-north-1
AWS_BUCKET=<your-bucket-name>
AWS_USE_PATH_STYLE_ENDPOINT=false

SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=true

MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=aSampleMasterKey

AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=${APP_URL}/login/azure/callback
AZURE_TENANT_ID=

TRANSLATIONIO_KEY=