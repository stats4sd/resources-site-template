{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "awcodes/shout": "^4.0",
        "chrisreedio/socialment": "^5.1",
        "filament/filament": "^5.0",
        "filament/spatie-laravel-media-library-plugin": "^5.0",
        "guzzlehttp/guzzle": "^7.2",
        "http-interop/http-factory-guzzle": "^1.2",
        "kainiklas/filament-scout": "^1.1",
        "lara-zeus/spatie-translatable": "^2.0",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.0",
        "laravel/scout": "^10.11",
        "laravel/tinker": "^3.0",
        "league/flysystem-aws-s3-v3": "^3.0",
        "livewire/livewire": "^4.0",
        "meilisearch/meilisearch-php": "^1.10",
        "parallax/filament-comments": "^3.0",
        "sentry/sentry-laravel": "^4.8",
        "socialiteproviders/microsoft-azure": "^5.2",
        "spatie/laravel-google-cloud-storage": "^2.4",
        "spatie/laravel-ignition": "^2.0",
        "spatie/laravel-permission": "^8.3",
        "spatie/laravel-ray": "^1.37",
        "symfony/http-client": "^8.0",
        "symfony/mailgun-mailer": "^8.0",
        "tio/laravel": "^1.23"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.17|^4.0",
        "fakerphp/faker": "^1.9.1",
        "laravel-shift/blueprint": "^2.7",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "laravel/telescope": "^5.20",
        "laravel/ui": "^4.2",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.8",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpunit/phpunit": "^12.0",
        "rector/rector": "^2.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "post-install-cmd": [
            "php artisan storage:link --quiet"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
